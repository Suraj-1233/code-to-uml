# Backend (Maven / Spring Boot)
backend/target/

# Frontend (Angular) — node_modules & dist are ignored by frontend/.gitignore too
frontend/node_modules/
frontend/dist/
frontend/.angular/

# OS / editor
.DS_Store
*.log

# Secrets / keys — never commit SSH private keys or env files
*.pem
*.key
.env
.env.*
!.env.example
